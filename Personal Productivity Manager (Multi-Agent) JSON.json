      "parameters": {
        "toolDescription": "Use this when the user wants to add a TASK or TO-DO item. Examples: \"I need to finish the report\", \"add task: clean room\".",
        "text": "={{ $fromAI(\"user_message\", \"the original user message about the task\", \"string\") }}",
        "options": {
          "systemMessage": "You are the Task Agent. Save the user task using the Save_Task tool.\n\nSteps:\n1. Extract a clear task description\n2. Decide priority: words like \"urgent\", \"asap\", \"important\" = High; everyday stuff = Medium; \"someday\", \"maybe\" = Low\n3. Call Save_Task tool\n4. Reply with: \"Task added: [task] (Priority: [priority])\""
        }
      },
